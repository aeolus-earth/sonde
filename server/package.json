{
  "name": "@sonde/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test:tool-policy": "node --import tsx --test src/mcp/tool-policy.test.ts",
    "test:sandbox-policy": "node --import tsx --test src/sandbox/sandbox-tool-policy.test.ts",
    "test": "node --import tsx --test src/*.test.ts src/**/*.test.ts",
    "smoke": "npm run build && node scripts/smoke.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.98",
    "@daytonaio/sdk": "^0.163.0",
    "@hono/node-ws": "^1.1.0",
    "@supabase/supabase-js": "^2.103.0",
    "dotenv": "^17.4.1",
    "hono": "^4.12.12",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/ws": "^8.5.0",
    "tsx": "^4.19.0",
    "typescript": "~6.0.2"
  },
  "engines": {
    "node": ">=20"
  }
}
