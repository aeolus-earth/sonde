# Sonde environment configuration
# Copy this file: cp .env.example .env
# Then fill in the values (ask team lead or check Supabase dashboard)

# ── Hosted Supabase ──────────────────────────────────────────────
AEOLUS_SUPABASE_URL=https://<project-ref>.supabase.co
AEOLUS_SUPABASE_KEY=<anon-key>
AEOLUS_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Optional: service role key for admin operations (artifact cleanup, etc.)
# AEOLUS_SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Local Supabase (uncomment for offline dev) ───────────────────
# Run `supabase start` first, then `supabase status` to get these values.
# AEOLUS_SUPABASE_URL=http://127.0.0.1:54321
# AEOLUS_SUPABASE_KEY=<local-anon-key>

# ── Agent auth (for CI/agents, not humans) ───────────────────────
# Humans authenticate via `sonde login` (OAuth browser flow).
# Agents use a token: ask team lead or generate via `sonde admin token`.
# SONDE_TOKEN=sonde_at_<token>
